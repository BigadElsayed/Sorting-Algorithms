<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<BorderPane prefHeight="700.0" prefWidth="1180.0" style="-fx-background-color: #1a0a0a;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="UI.comparison.ComparisonController">

    <left>
        <VBox prefHeight="120.0" prefWidth="260" spacing="12" style="-fx-background-color: #2d0f0f;                        -fx-padding: 15px;                        -fx-border-color: #5c1a1a;                        -fx-border-width: 0 2 0 0;">

            <!-- Title -->
            <Label style="-fx-text-fill: #e74c3c;                           -fx-font-size: 16px;                           -fx-font-weight: bold;" text="⚙ Settings" />

            <!-- ── Algorithms Section ── -->
            <Label style="-fx-text-fill: #d5a5a5;                           -fx-font-size: 12px;                           -fx-font-weight: bold;" text="Algorithms:" />

            <CheckBox fx:id="bubbleCheck" selected="true" style="-fx-text-fill: white; -fx-font-size: 13px;" text="Bubble Sort" />

            <CheckBox fx:id="insertionCheck" selected="true" style="-fx-text-fill: white; -fx-font-size: 13px;" text="Insertion Sort" />

            <CheckBox fx:id="selectionCheck" selected="true" style="-fx-text-fill: white; -fx-font-size: 13px;" text="Selection Sort" />

            <CheckBox fx:id="mergeCheck" selected="true" style="-fx-text-fill: white; -fx-font-size: 13px;" text="Merge Sort" />

            <CheckBox fx:id="heapCheck" selected="true" style="-fx-text-fill: white; -fx-font-size: 13px;" text="Heap Sort" />

            <CheckBox fx:id="quickCheck" selected="true" style="-fx-text-fill: white; -fx-font-size: 13px;" text="Quick Sort" />

            <!-- ── Array Type Section ── -->
            <Label style="-fx-text-fill: #d5a5a5;                           -fx-font-size: 12px;                           -fx-font-weight: bold;" text="Array Type:" />

            <ComboBox fx:id="arrayTypeCombo" prefWidth="230" style="-fx-background-color: #3d1515;                              -fx-text-fill: white;                              -fx-font-size: 13px;                              -fx-border-color: #8b0000;                              -fx-border-radius: 3;" />

            <!-- ── Array Size Section ── -->
            <Label style="-fx-text-fill: #d5a5a5;                           -fx-font-size: 12px;                           -fx-font-weight: bold;" text="Array Size (max 10,000):" />

            <TextField fx:id="arraySizeField" style="-fx-background-color: #3d1515;                               -fx-text-fill: white;                               -fx-prompt-text-fill: #a06060;                               -fx-font-size: 13px;                               -fx-border-color: #8b0000;                               -fx-border-radius: 3;" />

            <!-- ── Number of Runs Section ── -->
            <Label style="-fx-text-fill: #d5a5a5;                           -fx-font-size: 12px;                           -fx-font-weight: bold;" text="Number of Runs:" />

            <TextField fx:id="numRunsField" style="-fx-background-color: #3d1515;                               -fx-text-fill: white;                               -fx-prompt-text-fill: #a06060;                               -fx-font-size: 13px;                               -fx-border-color: #8b0000;                               -fx-border-radius: 3;" />

            <!-- ── File Input Section ── -->
            <Label style="-fx-text-fill: #d5a5a5;                           -fx-font-size: 12px;                           -fx-font-weight: bold;" text="Input Files:" />

            <Button fx:id="addFileButton" onAction="#handleAddFile" prefWidth="230" style="-fx-background-color: #6b1a1a;                            -fx-text-fill: white;                            -fx-font-size: 13px;                            -fx-cursor: hand;                            -fx-border-color: #8b0000;                            -fx-border-radius: 3;                            -fx-background-radius: 3;" text="Add File" />
            <Button fx:id="clearFileButton" onAction="#handleClearFile" prefHeight="26.0" prefWidth="260.0" style="-fx-background-color: #4a0a0a;                         -fx-text-fill: #d5a5a5;                         -fx-font-size: 11px;                         -fx-cursor: hand;                         -fx-border-color: #8b0000;                         -fx-border-radius: 3;                         -fx-background-radius: 3;" text="✕ Clear Files" />

            <!-- List of added files -->
            <ListView fx:id="fileListView" prefHeight="80" prefWidth="230" style="-fx-background-color: #3d1515;                              -fx-control-inner-background: #3d1515;                              -fx-font-size: 11px;                              -fx-border-color: #8b0000;" />

            <!-- ── Action Buttons ── -->
            <Button fx:id="runButton" onAction="#handleRun" prefHeight="40.0" prefWidth="230.0" style="-fx-background-color: #8b0000;                            -fx-text-fill: white;                            -fx-font-size: 14px;                            -fx-font-weight: bold;                            -fx-cursor: hand;                            -fx-background-radius: 4;                            -fx-border-radius: 4;" text="▶ Run Comparison" />

            <Button fx:id="clearButton" onAction="#handleClear" prefWidth="230.0" style="-fx-background-color: #4a0a0a;                            -fx-text-fill: #d5a5a5;                            -fx-font-size: 13px;                            -fx-cursor: hand;                            -fx-border-color: #8b0000;                            -fx-border-radius: 3;                            -fx-background-radius: 3;" text="🗑 Clear Results" />

            <Button fx:id="exportButton" onAction="#handleExport" prefWidth="230" style="-fx-background-color: #4a0a0a;                            -fx-text-fill: #d5a5a5;                            -fx-font-size: 13px;                            -fx-cursor: hand;                            -fx-border-color: #8b0000;                            -fx-border-radius: 3;                            -fx-background-radius: 3;" text="💾 Export CSV" />

            <!-- Status label -->
            <Label fx:id="statusLabel" prefWidth="230" style="-fx-text-fill: #e74c3c;                           -fx-font-size: 11px;                           -fx-font-style: italic;" wrapText="true" />

        </VBox>
    </left>

    <center>
        <VBox spacing="10" style="-fx-background-color: #1a0a0a;                      -fx-padding: 15px;">

            <!-- Table Title -->
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label style="-fx-font-size: 16px;                               -fx-font-weight: bold;                               -fx-text-fill: #e74c3c;" text="📊 Comparison Results" />

                <Label fx:id="rowCountLabel" style="-fx-font-size: 12px;                               -fx-text-fill: #d5a5a5;" />
            </HBox>

            <!-- Results Table -->
            <TableView fx:id="resultsTable" style="-fx-background-color: #2d0f0f;                               -fx-control-inner-background: #2d0f0f;                               -fx-table-cell-border-color: #5c1a1a;                               -fx-font-size: 12px;                               -fx-text-fill: white;                               -fx-border-color: #8b0000;" VBox.vgrow="ALWAYS">

                <columns>

                    <TableColumn fx:id="algoCol" prefWidth="130" text="Algorithm" />

                    <TableColumn fx:id="sizeCol" prefWidth="90" text="Array Size" />

                    <TableColumn fx:id="sourceCol" prefWidth="130" text="Array Type" />

                    <TableColumn fx:id="runsCol" prefWidth="50" text="Runs" />

                    <TableColumn fx:id="avgCol" prefWidth="110" text="Avg Runtime" />

                    <TableColumn fx:id="minCol" prefWidth="110" text="Min Runtime" />

                    <TableColumn fx:id="maxCol" prefWidth="110" text="Max Runtime" />

                    <TableColumn fx:id="compCol" prefWidth="110" text="Comparisons" />

                    <TableColumn fx:id="interCol" prefWidth="110" text="Interchanges" />

                </columns>

                <placeholder>
                    <Label style="-fx-text-fill: #d5a5a5; -fx-font-size: 13px;" />
                </placeholder>

            </TableView>

        </VBox>
    </center>

</BorderPane>
